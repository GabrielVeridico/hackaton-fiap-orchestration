# ----------------------------------------------------------------------------
# Conexão Solidária — variáveis do ambiente local (docker-compose).
# Copie para `.env` (NÃO commitado) e ajuste conforme necessário:
#   cp .env.example .env
# ----------------------------------------------------------------------------

# SQL Server (usuário sa). Usado pelas 3 APIs e pelo backing do Service Bus emulator.
# A senha precisa ser forte (política do SQL Server): >=8 chars, maiúscula, minúscula, número.
SA_PASSWORD=Your_password123

# JWT — a MESMA chave precisa estar nos 3 serviços, pois o token emitido no login
# (UserAPI) é validado por Payments e Donations (mesmo issuer/audience).
JWT_KEY=dev-super-secret-jwt-key-change-me-please-min-32-bytes
JWT_ISSUER=conexaosolidaria.local
JWT_AUDIENCE=conexaosolidaria.clients

# Senha do Owner semeado pela UserAPI no primeiro start.
OWNER_PASSWORD=Owner@123
